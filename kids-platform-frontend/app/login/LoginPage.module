.page {
  position: relative;
  min-height: 100vh;
  color: #fff;
  overflow-x: hidden;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
}

.bg {
  position: absolute;
  inset: 0;
  background-image: url("/background.png");
  background-size: cover;
  background-position: center;
  transform: scale(1.02);
  filter: saturate(1.1);
}


.header {
  position: relative;
  z-index: 2;
  padding: 18px 16px;
}

.headerInner {
  max-width: 1100px;
  margin: 0 auto;

  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;

  padding: 14px 18px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: rgba(40, 26, 70, 0.35);
  backdrop-filter: blur(10px);
  box-shadow: 0 14px 40px rgba(0, 0, 0, 0.35);
}

.brandTitle {
  font-weight: 900;
  letter-spacing: 0.4px;
  font-size: 18px;
}

.brandSub {
  font-size: 12px;
  opacity: 0.8;
  margin-top: 2px;
}

.nav {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.navLink {
  color: rgba(255, 255, 255, 0.9);
  text-decoration: none;
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.06);
  transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
}

.navLink:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.25);
  transform: translateY(-1px);
}

.main {
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 140px);
  display: grid;
  place-items: center;
  padding: 18px 14px 26px;
}

.card {
  width: 100%;
  max-width: 420px;
  box-sizing: border-box;
  border-radius: 22px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: rgba(25, 14, 50, 0.55);
  backdrop-filter: blur(12px);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.45);

  padding: 18px;
}

.card * {
  box-sizing: border-box;
  max-width: 100%;
}

.title {
  margin: 0;
  font-size: 28px;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 8px 26px rgba(0, 0, 0, 0.55);
}

.subTitle {
  margin: 8px 0 16px;
  text-align: center;
  opacity: 0.85;
  font-size: 14px;
}

.form {
  display: grid;
  gap: 12px;
}

.label {
  display: grid;
  gap: 6px;
  font-size: 13px;
  opacity: 0.95;
}

.input {
  width: 100%;
  max-width: 100%;

  border-radius: 14px;
  padding: 12px 12px;

  border: 1px solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08);
  color: rgb(255, 255, 255);
  outline: none;
}

.input::placeholder {
  color: rgba(255, 255, 255, 0.55);
}

.passwordWrap {
  position: relative;
  display: flex;
  align-items: center;
}

.passwordWrap .input {
  padding-right: 46px;
}

.togglePass {
  position: absolute;
  right: 10px;
  top: 50%;
  transform: translateY(-50%);

  width: 36px;
  height: 36px;
  border-radius: 10px;

  border: none;
  background: transparent;
  color: rgba(255, 255, 255, 0.7);

  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.togglePass:hover {
  color: rgba(255, 255, 255, 1);
}

.err {
  border-radius: 14px;
  padding: 10px 12px;
  border: 1px solid rgba(255, 80, 80, 0.35);
  background: rgba(20, 12, 40, 0.45);
}

.primaryBtn {
  margin-top: 4px;
  width: 100%;
  border-radius: 16px;
  padding: 12px 14px;
  border: 1px solid rgba(120, 255, 180, 0.22);
  background: linear-gradient(to bottom, rgba(90, 210, 120, 0.95), rgba(40, 160, 90, 0.95));
  color: #06220f;
  font-weight: 900;
  cursor: pointer;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
}

.primaryBtn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.links {
  margin-top: 14px;
  display: grid;
  gap: 8px;
  text-align: center;
}

.linkRow {
  font-size: 13px;
  opacity: 0.9;
}

.link {
  color: #fff;
  font-weight: 900;
  text-decoration: none;
  border-bottom: 1px dashed rgba(255, 255, 255, 0.35);
}

.link:hover {
  border-bottom-color: rgba(255, 255, 255, 0.7);
}

.footer {
  position: relative;
  z-index: 2;
  padding: 12px 16px 18px;
}

.footerInner {
  max-width: 1100px;
  margin: 0 auto;
  opacity: 0.75;
  font-size: 12px;
  text-align: center;
}

@media (max-width: 520px) {
  .headerInner {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
  }

  .brandTitle {
    font-size: 16px; 
  }

  .brandSub {
    font-size: 11px; 
  }

  .nav {
    width: 100%;
    justify-content: center; 
    gap: 10px;
  }

  .navLink {
    padding: 9px 12px;
    font-size: 14px;
  }

  .main {
    padding: 16px 12px 22px; 
  }

  .card {
    padding: 16px;
    border-radius: 18px;
  }

  .title {
    font-size: 24px; 
  }

  .subTitle {
    font-size: 13px; 
  }
}

@media (max-width: 360px) {
  .nav {
    flex-direction: column;
    align-items: stretch;
  }

  .navLink {
    width: 100%;
    text-align: center;
  }
}
